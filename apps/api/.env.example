APP_NAME=Yao Lawyer API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true

DATABASE_URL=sqlite:///./data/yao_lawyer.db
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_HOURS=72
SMS_CODE_TTL_SECONDS=300

AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_TIMEOUT_SECONDS=15
AI_MODEL_HIGH=gpt-4o-mini
AI_MODEL_LOW=gpt-4o-mini

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS_PER_WINDOW=40
QUEUE_ETA_SECONDS=45
FREE_CHAT_QUOTA=10
FREE_REPORT_QUOTA=1

